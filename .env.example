# printd configuration — copy to .env and edit

# Auth — leave empty for dev mode (no auth, logs a warning at startup)
PRINTD_API_KEY=changeme

# Bind
PRINTD_HOST=0.0.0.0
PRINTD_PORT=8080

# Printer wiring
# Kind: usb | network | serial | dummy
PRINTD_PRINTER_KIND=usb
# For usb:     /dev/usb/lp0
# For network: 192.168.1.50:9100
# For serial:  /dev/ttyUSB0
PRINTD_DEVICE=/dev/usb/lp0

# Image pipeline
PRINTD_PRINT_WIDTH=576
PRINTD_BOTTOM_PAD_ROWS=24
PRINTD_FEED_BEFORE_CUT=4

# CORS — comma-separated origins, or * for any
PRINTD_CORS_ORIGINS=*

# Safety
PRINTD_MAX_IMAGE_BYTES=8388608
